{
  "name": "han-li-life-database",
  "version": "1.1.0",
  "private": true,
  "description": "韩立人生数据库 — Han Li · Life Database",
  "scripts": {
    "postinstall": "node scripts/copy-fonts.mjs",
    "data:export": "node scripts/export-data.mjs",
    "schema:dump": "tsx scripts/dump-schema.ts",
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "npm run data:export && NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL:-https://hanli-life-database.pages.dev} NEXT_OUTPUT=export next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/noto-serif-sc": "^5.2.9",
    "better-sqlite3": "^12.9.0",
    "lucide-react": "^1.16.0",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
